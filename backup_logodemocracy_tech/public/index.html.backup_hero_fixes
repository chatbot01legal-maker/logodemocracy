<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ABOLEGAL - Asistente Legal Inteligente</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Header con Logo ABOLEGAL -->
    <!-- Header con Logo ABOLEGAL - Igual que footer -->
    <header class="header">
        <div class="header-container">
            <div class="footer-logo">
                <img src="https://assets.zyrosite.com/YBgeevgVBWuK9oxP/logo-abolegal-Yanqqv4opDI900al.png" alt="ABOLEGAL" class="footer-logo-img">
            </div>
        </div>
    </header>
    <!-- Header / Navegación -->
        <div class="hero-container">
            <div class="hero-content">
                <h1 class="hero-title-centered">Asistente Legal 24/7</h1>
                <p class="hero-subtitle">Orientación legal clara, empática y precisa.</p>
                <div class="hero-buttons">
                    <a href="#chat" class="btn btn-secondary">
                        <i class="fas fa-robot"></i> Asistente Legal
                    </a>
                    <a href="#servicios" class="btn btn-secondary">
                        <i class="fas fa-gavel"></i> Servicios
                    </a>
                    <a href="#contacto" class="btn btn-secondary">
                        <i class="fas fa-envelope"></i> Contacto
                    </a>
                    <a href="#agendar" class="btn btn-secondary">
                        <i class="fas fa-calendar-alt"></i> Agenda
                    </a>
                </div>
            </div>
            <div class="hero-image">
                <div class="chat-preview">
                    <div class="chat-preview-header">
                        <i class="fas fa-robot"></i>
                        <span>Lex - Asistente Legal</span>
                    </div>
                    <div class="chat-preview-messages">
                        <div class="message bot">¡Hola! Soy Lex, ¿en qué puedo ayudarte?</div>
                        <div class="message user">Me despidieron de mi trabajo</div>
                        <div class="message bot">Lamento escuchar eso. ¿Tenías contrato firmado?</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Chat Widget Section -->
    <section id="chat" class="chat-section">
        <div class="section-header">
            <h2 class="section-title">Habla con <span class="highlight">Lex, nuestro Asistente Legal</span></h2>
            <p class="section-subtitle">Orientación legal inicial 24/7 • Respuestas en tiempo real • Especializado en derecho chileno</p>
        </div>

        <div class="chat-container">
            <div class="chat-widget">
                <div class="chat-header">
                    <div class="chat-title">
                        <i class="fas fa-robot"></i>
                        <div>
                            <h3>Lex - Asistente Legal</h3>
                            <p class="chat-subtitle">Especializado en derecho chileno</p>
                        </div>
                    </div>
                    <div class="chat-status">
                        <div class="status-dot"></div>
                        <span>En línea 24/7</span>
                    </div>
                </div>

                <div class="chat-messages" id="chatMessages">
                    <div class="message bot">
                        <strong>Lex:</strong> ¡Hola! Soy Lex, tu asistente legal. Estoy aquí para orientarte en temas legales de Chile. ¿En qué puedo ayudarte hoy?
                    </div>
                    <div class="message user">
                        <strong>Tú:</strong> Me acabo de separar, ¿qué debo hacer?
                    </div>
                    <div class="message bot">
                        <strong>Lex:</strong> Lamento escuchar eso. Es una situación difícil. ¿Tienes hijos en común o temas de propiedad que resolver?
                    </div>
                </div>

                <div class="chat-input-area">
                    <input type="text" id="userInput" placeholder="Escribe tu consulta legal aquí...">
                    <button id="sendButton">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>

            </div>

            <div class="chat-info">
                <h3><i class="fas fa-lightbulb"></i> ¿Cómo te ayuda Lex?</h3>
                <ul>
                    <li><i class="fas fa-check"></i> <strong>Orientación inmediata</strong> las 24 horas</li>
                    <li><i class="fas fa-check"></i> <strong>Explicaciones claras</strong> en lenguaje simple</li>
                    <li><i class="fas fa-check"></i> <strong>Información actualizada</strong> sobre leyes chilenas</li>
                    <li><i class="fas fa-check"></i> <strong>Derivación a abogado</strong> cuando sea necesario</li>
                </ul>

                <div class="disclaimer-box">
                    <h4><i class="fas fa-exclamation-triangle"></i> Importante</h4>
                    <p>Lex es un asistente informativo. No reemplaza la asesoría de un abogado. Para situaciones complejas, recomendamos agendar consulta.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Calendar Section -->
    <section id="agendar" class="calendar-section">
        <div class="section-header">
            <h2 class="section-title">Agenda una <span class="highlight">Videollamada con un Abogado</span></h2>
            <p class="section-subtitle">Consulta de 30 minutos sin costo inicial • Horarios flexibles • Confidencialidad garantizada</p>
        </div>

        <div class="calendar-container">
            <div class="calendar-widget">
                <div class="calendar-header">
                    <h3><i class="fas fa-calendar-alt"></i> Selecciona Fecha y Hora</h3>
                    <p>Disponibilidad para las próximas 2 semanas</p>
                </div>

                <div class="calendar-content">
                    <!-- Selector de fecha simplificado -->
                    <div class="date-selector">
                        <h4><i class="fas fa-calendar-day"></i> Próximas fechas disponibles:</h4>
                        <div class="date-options">
                            <button class="date-option" onclick="selectDate('2024-01-26')">
                                <span class="day">Vie</span>
                                <span class="date">26 Ene</span>
                            </button>
                            <button class="date-option" onclick="selectDate('2024-01-29')">
                                <span class="day">Lun</span>
                                <span class="date">29 Ene</span>
                            </button>
                            <button class="date-option" onclick="selectDate('2024-01-30')">
                                <span class="day">Mar</span>
                                <span class="date">30 Ene</span>
                            </button>
                            <button class="date-option" onclick="selectDate('2024-01-31')">
                                <span class="day">Mié</span>
                                <span class="date">31 Ene</span>
                            </button>
                        </div>
                    </div>

                    <!-- Selector de hora -->
                    <div class="time-selector">
                        <h4><i class="fas fa-clock"></i> Horarios disponibles:</h4>
                        <div class="time-slots">
                            <button class="time-slot" onclick="selectTime('09:00')">09:00 AM</button>
                            <button class="time-slot" onclick="selectTime('10:00')">10:00 AM</button>
                            <button class="time-slot" onclick="selectTime('11:00')">11:00 AM</button>
                            <button class="time-slot" onclick="selectTime('14:00')">02:00 PM</button>
                            <button class="time-slot" onclick="selectTime('15:00')">03:00 PM</button>
                            <button class="time-slot" onclick="selectTime('16:00')">04:00 PM</button>
                        </div>
                    </div>

                    <!-- Formulario de reserva -->
                    <form class="booking-form" id="bookingForm">
                        <h4><i class="fas fa-user-edit"></i> Completa tus datos</h4>
                        
                        <div class="selected-slot">
                            <p id="selectedDateTime">Fecha y hora seleccionadas: <span class="highlight">Por favor selecciona fecha y hora</span></p>
                        </div>

                        <div class="form-group">
                            <input type="text" id="clientName" placeholder="Nombre completo" required>
                        </div>

                        <div class="form-group">
                            <input type="email" id="clientEmail" placeholder="Correo electrónico" required>
                        </div>

                        <div class="form-group">
                            <input type="tel" id="clientPhone" placeholder="Teléfono (opcional)">
                        </div>

                        <div class="form-group">
                            <textarea id="clientTopic" rows="3" placeholder="Breve descripción del tema legal (opcional)"></textarea>
                        </div>

                        <div class="form-group">
                            <button type="button" class="btn btn-secondary" id="sendSummaryBtn">
                                <i class="fas fa-file-alt"></i> Enviar un resumen de la conversación con Lex al abogado
                            </button>
                        </div>

                        <button type="submit" class="btn-book">
                            <i class="fas fa-calendar-check"></i> Reservar Videollamada
                        </button>

                        <p class="form-note">
                            <i class="fas fa-lock"></i> Tus datos son confidenciales. Recibirás un email de confirmación con el link de Zoom.
                        </p>
                    </form>
                </div>
            </div>

            <div class="calendar-info">
                <h3><i class="fas fa-info-circle"></i> ¿Qué incluye la videollamada?</h3>
                <ul class="benefits-list">
                    <li><i class="fas fa-check"></i> <strong>30 minutos</strong> con abogado especializado</li>
                    <li><i class="fas fa-check"></i> <strong>Análisis inicial</strong> de tu situación legal</li>
                    <li><i class="fas fa-check"></i> <strong>Orientación</strong> sobre próximos pasos</li>
                    <li><i class="fas fa-check"></i> <strong>Presupuesto</strong> sin compromiso si necesitas más ayuda</li>
                </ul>

                <div class="how-it-works">
                    <h4><i class="fas fa-play-circle"></i> Cómo funciona:</h4>
                    <ol>
                        <li><strong>Selecciona fecha y hora</strong> que te acomoden</li>
                        <li><strong>Completa tus datos</strong> de contacto</li>
                        <li><strong>Recibirás confirmación</strong> por email con link de Zoom</li>
                        <li><strong>Conéctate a la videollamada</strong> en el horario agendado</li>
                    </ol>
                </div>

            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="servicios" class="services-section">
        <div class="section-header">
            <h2>Nuestras <span class="highlight">Áreas de Especialización</span></h2>
            <p class="section-subtitle">Lex está entrenado en múltiples áreas del derecho chileno</p>
        </div>

        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-briefcase"></i>
                </div>
                <h3>Derecho Laboral</h3>
                <p>Despidos, finiquitos, acoso laboral, contratos, horas extras</p>
            </div>

            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-home"></i>
                </div>
                <h3>Derecho de Familia</h3>
                <p>Divorcios, pensión alimenticia, cuidado personal, violencia intrafamiliar</p>
            </div>

            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-balance-scale"></i>
                </div>
                <h3>Derecho Civil</h3>
                <p>Contratos, arriendos, compraventa, responsabilidad civil, sucesiones</p>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contacto" class="contact-section">
        <div class="section-header">
            <h2><span class="highlight">Contacto</span></h2>
            <p class="section-subtitle">¿Necesitas asesoría legal personalizada?</p>
        </div>

        <div class="contact-container">
            <div class="contact-info">
                <h3><i class="fas fa-map-marker-alt"></i> Estudio ABOLEGAL</h3>
                <p><i class="fas fa-envelope"></i> contacto@abolegal.cl</p>
                <p><i class="fas fa-phone"></i> +56 2 2345 6789</p>
                <p><i class="fas fa-clock"></i> Lunes a Viernes: 9:00 - 18:00</p>

                <div class="social-links">
                    <a href="#"><i class="fab fa-whatsapp"></i></a>
                    <a href="#"><i class="fab fa-linkedin"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                </div>
            </div>

            <div class="contact-form">
                <form id="contactForm">
                    <input type="text" placeholder="Tu nombre" required>
                    <input type="email" placeholder="Correo electrónico" required>
                    <input type="tel" placeholder="Teléfono (opcional)">
                    <textarea placeholder="¿En qué podemos ayudarte?" rows="4" required></textarea>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane"></i> Enviar Mensaje
                    </button>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-logo">
                <img src="https://assets.zyrosite.com/YBgeevgVBWuK9oxP/logo-abolegal-Yanqqv4opDI900al.png" alt="ABOLEGAL" class="footer-logo-img">
            </div>

            <div class="footer-links">
                <a href="#inicio">Inicio</a>
                <a href="#chat">Asistente Legal</a>
                <a href="#servicios">Servicios</a>
                <a href="#agendar">Agendar</a>
                <a href="#contacto">Contacto</a>
            </div>

            <div class="footer-legal">
                <p>© 2026 ABOLEGAL. Todos los derechos reservados.</p>
                <p>Este servicio es informativo y no constituye asesoría legal formal.</p>
            </div>
        </div>
    </footer>

    <!-- Script principal con la lógica del chat -->
    <script src="app.js"></script>
    <!-- Script adicional para funcionalidades específicas -->
    <script src="script.js"></script>
</body>
</html>
