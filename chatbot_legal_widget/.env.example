# ============================================
# VARIABLES DE INFRAESTRUCTURA PURA
# Widget de Agendamiento - NO contiene variables de Lex
# ============================================

# 🔐 GOOGLE CALENDAR API (OAuth2)
# Obtener desde Google Cloud Console
CLIENT_ID=tu_client_id_google
CLIENT_SECRET=tu_client_secret_google
REFRESH_TOKEN=tu_refresh_token_google
GOOGLE_CALENDAR_ID=primary
CALENDAR_TIMEZONE=America/Santiago
REDIRECT_URI=https://developers.google.com/oauthplayground

# 📧 EMAIL SERVICE (Notificaciones técnicas)
# Usar contraseña de aplicación de Gmail
EMAIL_USER=notificaciones@abolegal.cl
EMAIL_PASSWORD=tu_contraseña_app_gmail
LAWYER_EMAIL=abogado@abolegal.cl

# 🔗 SERVER CONFIG
PORT=10000
NODE_ENV=production

# ============================================
# NOTA: Variables de Lex (GEMINI_API_KEY, etc.) 
# se configuran en el backend de Lex, NO aquí
# ============================================

# Para desarrollo local, copiar este archivo a .env y completar valores
